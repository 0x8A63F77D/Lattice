<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pin the package source so a fresh clone restores regardless of
       machine-global NuGet configuration (issue #14). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- <clear/> above only resets the packageSources node; a machine-global
       disabledPackageSources entry for nuget.org would still win without this. -->
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
