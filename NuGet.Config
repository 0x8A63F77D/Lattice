<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pin the package source so a fresh clone restores regardless of
       machine-global NuGet configuration (issue #14). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- <clear/> above only resets the packageSources node; machine-global
       disabledPackageSources entries and packageSourceMapping rules are
       inherited separately and would still win without their own clears. -->
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
