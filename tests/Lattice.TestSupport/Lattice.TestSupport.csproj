<Project Sdk="Microsoft.NET.Sdk">
  <!-- xunit-free shared test doubles. Namespace stays Lattice.Tests deliberately: these types
       predate the split and both xunit v2 (Lattice.Tests) and v3 (Lattice.App.Tests) consumers
       keep their callsites unchanged. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <!-- Base Avalonia only (no theme/platform heads): HeadlessLayout needs Window,
         Size/Rect and Dispatcher. Headless-specific packages stay in the consumers. -->
    <PackageReference Include="Avalonia" Version="12.1.0" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" Version="10.7.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../src/Lattice.Boinc.GuiRpc/Lattice.Boinc.GuiRpc.csproj" />
    <ProjectReference Include="../../src/Lattice.Core/Lattice.Core.csproj" />
  </ItemGroup>
</Project>
