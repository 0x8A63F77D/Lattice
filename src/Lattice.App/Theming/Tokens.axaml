<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Design tokens: docs/design/m2/README.md §Design Tokens. UI code references
       these keys only; literal hexes must not appear outside this file. -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="LatticeCanvasBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="LatticeSurfaceBrush" Color="#FFFFFF" />
      <!-- Command-bar region surface. The design groups the nav and command-bar as one Mica region
           ("the nav and command-bar regions use Mica material; #202020 is the solid fallback"), so its
           opaque fallback is the NAV-region colour (#F5F5F5 light / #202020 dark = LatticeNavSurfaceBrush),
           NOT the content surface. The shell flips a window-level override of THIS key transparent when
           Mica is granted; kept a separate key from LatticeNavSurfaceBrush so the command-bar toggle
           never touches the nav pane, and from LatticeSurfaceBrush (loading/empty overlays, always opaque). -->
      <SolidColorBrush x:Key="LatticeCommandBarSurfaceBrush" Color="#F5F5F5" />
      <SolidColorBrush x:Key="LatticeNavSurfaceBrush" Color="#F5F5F5" />
      <SolidColorBrush x:Key="LatticeStrokeBrush" Color="#E0E0E0" />
      <SolidColorBrush x:Key="LatticeStrokeSubtleBrush" Color="#F0F0F0" />
      <SolidColorBrush x:Key="LatticeTextPrimaryBrush" Color="#242424" />
      <SolidColorBrush x:Key="LatticeTextSecondaryBrush" Color="#616161" />
      <SolidColorBrush x:Key="LatticeTextTertiaryBrush" Color="#767676" />
      <SolidColorBrush x:Key="LatticeAccentBrush" Color="#0F6CBD" />
      <SolidColorBrush x:Key="LatticeSelectedTintBrush" Color="#EBF3FC" />
      <SolidColorBrush x:Key="LatticeSuccessBrush" Color="#107C10" />
      <SolidColorBrush x:Key="LatticeWarningFgBrush" Color="#BC4B09" />
      <SolidColorBrush x:Key="LatticeWarningTintBrush" Color="#FFF9F5" />
      <SolidColorBrush x:Key="LatticeDangerFgBrush" Color="#C50F1F" />
      <SolidColorBrush x:Key="LatticeDangerTintBrush" Color="#FDF3F4" />
      <SolidColorBrush x:Key="LatticeNeutralFgBrush" Color="#616161" />
      <SolidColorBrush x:Key="LatticeDisabledBrush" Color="#BDBDBD" />
      <SolidColorBrush x:Key="LatticeGridDividerBrush" Color="#EDEBE9" />
      <SolidColorBrush x:Key="LatticeRowHoverBrush" Color="#F5F5F5" />
      <!-- Elevation for small floating overlays (the partial-results card): the spec's
           shadow16 ramp (design card 1g: 0 0 2 rgba(0,0,0,.12), 0 8 16 rgba(0,0,0,.14)). -->
      <BoxShadows x:Key="LatticeOverlayShadow">0 0 2 0 #1F000000, 0 8 16 0 #24000000</BoxShadows>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="LatticeCanvasBrush" Color="#1F1F1F" />
      <SolidColorBrush x:Key="LatticeSurfaceBrush" Color="#292929" />
      <!-- Command-bar region surface — see the Light dictionary. Dark region fallback #202020 (the
           design's stated Mica solid fallback = nav colour), aligned from the old #292929 surface per
           owner decision (2026-07-19: "按照设计稿执行"). -->
      <SolidColorBrush x:Key="LatticeCommandBarSurfaceBrush" Color="#202020" />
      <SolidColorBrush x:Key="LatticeNavSurfaceBrush" Color="#202020" />
      <SolidColorBrush x:Key="LatticeStrokeBrush" Color="#3D3D3D" />
      <SolidColorBrush x:Key="LatticeStrokeSubtleBrush" Color="#333333" />
      <SolidColorBrush x:Key="LatticeTextPrimaryBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="LatticeTextSecondaryBrush" Color="#D6D6D6" />
      <SolidColorBrush x:Key="LatticeTextTertiaryBrush" Color="#ADADAD" />
      <SolidColorBrush x:Key="LatticeAccentBrush" Color="#479EF5" />
      <SolidColorBrush x:Key="LatticeSelectedTintBrush" Color="#123B5C" />
      <SolidColorBrush x:Key="LatticeSuccessBrush" Color="#9FD89F" />
      <SolidColorBrush x:Key="LatticeWarningFgBrush" Color="#FAA06B" />
      <SolidColorBrush x:Key="LatticeWarningTintBrush" Color="#3A2A1E" />
      <SolidColorBrush x:Key="LatticeDangerFgBrush" Color="#E37D80" />
      <SolidColorBrush x:Key="LatticeDangerTintBrush" Color="#3A1E20" />
      <SolidColorBrush x:Key="LatticeNeutralFgBrush" Color="#ADADAD" />
      <SolidColorBrush x:Key="LatticeDisabledBrush" Color="#5C5C5C" />
      <SolidColorBrush x:Key="LatticeGridDividerBrush" Color="#333333" />
      <!-- Deliberately gentle: a brighter dark hover (#383838) read as dazzling/eye-straining
           in the running app (owner visual verdict). #2D2D2D is a subtle step over the dark
           surface (#292929). Light hover (#F5F5F5) was not flagged; left as-is. -->
      <SolidColorBrush x:Key="LatticeRowHoverBrush" Color="#2D2D2D" />
      <!-- Dark mirror of the shadow16 elevation (1f is a token-substitution mirror; the
           Fluent dark ramp doubles the ambient/key alphas to .24/.28 — a light-ramp black
           shadow all but vanishes on the #1F1F1F canvas, which was the flagged weak spot). -->
      <BoxShadows x:Key="LatticeOverlayShadow">0 0 2 0 #3D000000, 0 8 16 0 #47000000</BoxShadows>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Variant-independent layout tokens -->
  <x:Double x:Key="LatticeNavWidth">260</x:Double>
  <x:Double x:Key="LatticeNavCompactWidth">48</x:Double>
  <x:Double x:Key="LatticeNavItemHeight">36</x:Double>
  <x:Double x:Key="LatticeHostItemHeight">40</x:Double>
  <x:Double x:Key="LatticeCommandBarHeight">52</x:Double>
  <x:Double x:Key="LatticeGridHeaderHeight">32</x:Double>
  <!-- Top inset that drops a data view's empty/loading overlay below the column
       header band (issue #88): the header stays visible AND hit-testable while an
       overlay is up. Top MUST equal LatticeGridHeaderHeight above; XAML can't
       derive a Thickness from that Double, so it is restated here and the coupling
       is enforced at runtime by OverlayHeaderClearanceTests (overlay top == header
       bottom in every view). Consumed by the Border.dataOverlay style. -->
  <Thickness x:Key="LatticeDataOverlayInset">0,32,0,0</Thickness>
  <x:Double x:Key="LatticeRowHeight">36</x:Double>
  <x:Double x:Key="LatticeRowHeightCompact">28</x:Double>
  <x:Double x:Key="LatticeStatusBarHeight">28</x:Double>
  <CornerRadius x:Key="LatticeSurfaceRadius">8</CornerRadius>
  <CornerRadius x:Key="LatticeControlRadius">4</CornerRadius>
  <Thickness x:Key="LatticePagePadding">16</Thickness>
  <x:Double x:Key="LatticeGap">8</x:Double>
</ResourceDictionary>
