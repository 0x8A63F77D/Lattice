<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lattice.App.ViewModels"
             x:Class="Lattice.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Margin="16"
             Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
</UserControl>
