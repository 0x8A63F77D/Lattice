<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Lattice.App.ViewModels"
             xmlns:loc="using:Lattice.App.Localization"
             xmlns:infra="using:Lattice.App.Infrastructure"
             xmlns:v="using:Lattice.App.Views"
             x:Class="Lattice.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <!-- Opaque content surface (design: content is always opaque). PageHost is transparent so the
       command-bar strip can reveal Mica; Settings has no command bar, so it paints the canvas across
       its whole area. Same canvas colour as before → fallback unchanged. -->
  <ScrollViewer Background="{DynamicResource LatticeCanvasBrush}">
    <StackPanel Margin="{StaticResource LatticePagePadding}" Spacing="8" MaxWidth="900">
      <TextBlock Text="{x:Static loc:Strings.SettingsTitle}" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource LatticeTextPrimaryBrush}" />

      <TextBlock Text="{x:Static loc:Strings.SettingsHostsPointer}" FontSize="12" Margin="0,4,0,8"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />

      <TextBlock Text="{x:Static loc:Strings.SettingsPollingSection}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ui:FASettingsExpander x:Name="PollingExpander" Header="{x:Static loc:Strings.SettingsPollingHeader}"
                             Description="{x:Static loc:Strings.SettingsPollingDescription}">
        <ui:FASettingsExpander.Footer>
          <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.AllowedPollingIntervals}"
                    SelectedItem="{Binding PollingIntervalSeconds, Mode=TwoWay}" />
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>
      <TextBlock Text="{Binding PollingError}" FontSize="12"
                 IsVisible="{Binding PollingError, Converter={x:Static ObjectConverters.IsNotNull}}"
                 Foreground="{DynamicResource LatticeDangerFgBrush}" />

      <TextBlock Text="{x:Static loc:Strings.SettingsThemeSection}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ui:FASettingsExpander x:Name="ThemeExpander"
                             Header="{x:Static loc:Strings.SettingsThemeHeader}"
                             Description="{x:Static loc:Strings.SettingsThemeDescription}">
        <ui:FASettingsExpander.Footer>
          <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.AllThemes}"
                    SelectedItem="{Binding SelectedTheme, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="infra:AppTheme">
                <TextBlock Text="{Binding Converter={x:Static v:ThemeLabelConverter.Instance}}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>

      <TextBlock Text="{x:Static loc:Strings.SettingsLanguageSection}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ui:FASettingsExpander x:Name="LanguageExpander"
                             Header="{x:Static loc:Strings.SettingsLanguageHeader}"
                             Description="{x:Static loc:Strings.SettingsLanguageDescription}">
        <ui:FASettingsExpander.Footer>
          <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.AllLanguages}"
                    SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="infra:AppLanguage">
                <TextBlock Text="{Binding Converter={x:Static v:LanguageLabelConverter.Instance}}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                  IsVisible="{Binding ShowLanguageRestartHint}">
        <TextBlock Text="{x:Static loc:Strings.SettingsLanguageRestartHint}" FontSize="12" TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
        <Button Content="{x:Static loc:Strings.SettingsLanguageRestartButton}"
                Command="{Binding RestartNowCommand}" />
      </StackPanel>

      <TextBlock Text="{x:Static loc:Strings.SettingsTraySection}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ui:FASettingsExpander x:Name="CloseToTrayExpander"
                             Header="{x:Static loc:Strings.SettingsCloseToTrayLabel}"
                             Description="{x:Static loc:Strings.SettingsCloseToTrayDescription}">
        <ui:FASettingsExpander.Footer>
          <ToggleSwitch IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>
      <ui:FASettingsExpander x:Name="FullSpeedHiddenExpander"
                             Header="{x:Static loc:Strings.SettingsFullSpeedHiddenLabel}"
                             Description="{x:Static loc:Strings.SettingsFullSpeedHiddenDescription}">
        <ui:FASettingsExpander.Footer>
          <ToggleSwitch IsChecked="{Binding FullSpeedHiddenPolling, Mode=TwoWay}" />
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>

      <TextBlock Text="{x:Static loc:Strings.SettingsAboutSection}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <!-- Label + version share ONE TextBlock (inline Runs) so they sit on a single text
           baseline. Two side-by-side TextBlocks in a horizontal StackPanel have different
           line-box heights when the label is CJK ("版本") and the value is Latin ("1.0.0"),
           which rendered the version visibly low under zh-CN (#147 owner report). -->
      <TextBlock FontSize="12">
        <Run Text="{x:Static loc:Strings.SettingsVersionLabel}" Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
        <Run Text=" " />
        <Run Text="{x:Static vm:SettingsViewModel.AppVersion}" Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
      </TextBlock>
    </StackPanel>
  </ScrollViewer>
</UserControl>
