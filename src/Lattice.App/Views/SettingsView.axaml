<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Lattice.App.ViewModels"
             x:Class="Lattice.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <ScrollViewer>
    <StackPanel Margin="{StaticResource LatticePagePadding}" Spacing="8" MaxWidth="900">
      <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource LatticeTextPrimaryBrush}" />

      <TextBlock Text="Hosts" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ItemsControl ItemsSource="{Binding Hosts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:HostSettingsItemViewModel">
            <ui:FASettingsExpander Header="{Binding DisplayName}"
                                   Description="{Binding StatusText}"
                                   IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                   Margin="0,0,0,4">
              <ui:FASettingsExpander.IconSource>
                <ui:FAPathIconSource Data="{StaticResource IconServerRegular}" />
              </ui:FASettingsExpander.IconSource>
              <StackPanel Spacing="8" Margin="0,4">
                <ui:FAInfoBar Severity="Error" IsOpen="{Binding HasAuthError}" IsClosable="False"
                              Title="Wrong password" Message="{Binding AuthErrorText}" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                           PlaceholderText="Defaults to the address" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Address" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Address, Mode=TwoWay}" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PortText, Mode=TwoWay}" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Password" VerticalAlignment="Center" />
                  <!-- Known limitation (accepted + ledger-tracked): Avalonia's TextBoxAutomationPeer
                       exposes the raw Text via UI Automation regardless of PasswordChar, and neither
                       Avalonia 12 nor FluentAvalonia 3 ships a first-party PasswordBox. -->
                  <TextBox Grid.Row="3" Grid.Column="1" PasswordChar="●"
                           Text="{Binding Password, Mode=TwoWay}"
                           PlaceholderText="From gui_rpc_auth.cfg" />
                </Grid>
                <TextBlock Text="{Binding ValidationError}" FontSize="12"
                           IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                           Foreground="{DynamicResource LatticeDangerFgBrush}" />
                <TextBlock Text="{Binding TestResultText}" FontSize="12"
                           IsVisible="{Binding TestResultText, Converter={x:Static ObjectConverters.IsNotNull}}"
                           Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Test connection" Command="{Binding TestConnectionCommand}" />
                  <Button Classes="accent" Content="Save" Command="{Binding SaveCommand}" />
                  <Button Content="Remove host" Command="{Binding RemoveCommand}"
                          Background="Transparent"
                          Foreground="{DynamicResource LatticeDangerFgBrush}" />
                </StackPanel>
              </StackPanel>
            </ui:FASettingsExpander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="Polling" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,0"
                 Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
      <ui:FASettingsExpander x:Name="PollingExpander" Header="Polling interval"
                             Description="How often each host is polled for status and tasks">
        <ui:FASettingsExpander.Footer>
          <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.AllowedPollingIntervals}"
                    SelectedItem="{Binding PollingIntervalSeconds, Mode=TwoWay}" />
        </ui:FASettingsExpander.Footer>
      </ui:FASettingsExpander>
      <TextBlock Text="{Binding PollingError}" FontSize="12"
                 IsVisible="{Binding PollingError, Converter={x:Static ObjectConverters.IsNotNull}}"
                 Foreground="{DynamicResource LatticeDangerFgBrush}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
