<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:Lattice.App.ViewModels"
        xmlns:v="using:Lattice.App.Views"
        xmlns:inf="using:Lattice.App.Infrastructure"
        xmlns:loc="using:Lattice.App.Localization"
        x:Class="Lattice.App.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        Title="{x:Static loc:Strings.AppTitle}"
        Icon="/Assets/lattice.ico"
        Width="1280" Height="800" MinWidth="1000" MinHeight="700"
        TransparencyLevelHint="Mica, None"
        TransparencyBackgroundFallback="{DynamicResource LatticeCanvasBrush}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding SelectViewCommand}" CommandParameter="0" />
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding SelectViewCommand}" CommandParameter="1" />
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding SelectViewCommand}" CommandParameter="2" />
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding SelectViewCommand}" CommandParameter="3" />
  </Window.KeyBindings>

  <Window.Styles>
    <!-- The only allowed looping animation: Connecting spinner, 1.5 s/rev linear -->
    <Style Selector="PathIcon.spin">
      <Setter Property="RenderTransform">
        <RotateTransform Angle="0" />
      </Setter>
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Selected host rail entry: brand tint + accent pill (design 1c) -->
    <Style Selector="ListBox.hostRail ListBoxItem">
      <Setter Property="Padding" Value="8,0" />
      <!-- Each rail container sizes to its template's explicit DockPanel height (28 header /
           36 grouped host / 40 flat & All-hosts). A 40px MinHeight would floor the shorter
           28/36px design-3a rows; the compact group-header collapse also needs 0 here. -->
      <Setter Property="MinHeight" Value="0" />
      <!-- The theme's ListBoxItem MinWidth (88) overflows the 48px compact rail:
           layout centers the oversized item at a negative offset and the state
           icon renders half-clipped at the pane edge. Rail entries stretch to
           whatever width the pane gives them. -->
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="CornerRadius" Value="{StaticResource LatticeControlRadius}" />
    </Style>
    <!-- FluentAvalonia's ListBoxItem template insets its ContentPresenter by 2px on every
         side. That 4px of vertical chrome would make every rail row 4px taller than its
         template's explicit DockPanel height (design 3a rows are 28 header / 36 grouped host /
         40 flat — the RENDERED row height, card 1g), and would leave a 4px ghost row where a
         compact group-header collapses to zero content. Zero the inset so the container height
         equals the DockPanel height; the selection tint then fills the full row. -->
    <Style Selector="ListBox.hostRail ListBoxItem /template/ ContentPresenter">
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="ListBox.hostRail ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource LatticeSelectedTintBrush}" />
    </Style>
    <!-- Host-row context menu items: 32px rows (design 3b). -->
    <Style Selector="MenuFlyoutPresenter MenuItem">
      <Setter Property="MinHeight" Value="32" />
    </Style>
  </Window.Styles>

  <Panel>
    <!-- First-run empty state is a CONTENT surface (design: content surfaces are always opaque).
         It sits at the shell root, NOT inside PageHost, so it needs its own canvas paint — without
         it a granted Mica would show through the empty state on a new install (window background is
         transparent under Mica). Same canvas colour the window painted before, so the opaque
         fallback is unchanged. -->
    <v:FirstRunView x:Name="FirstRun" x:FieldModifier="public" IsVisible="{Binding !HasHosts}"
                    Background="{DynamicResource LatticeCanvasBrush}" />

    <!-- Responsive rail (design 1i / card 3a; README:104): the pane auto-collapses to the 48px
         compact strip below 1280px window width and is fully open (260px) at >= 1280. FA's native
         adaptive PaneDisplayMode="Auto" drives it: it flips IsPaneOpen itself (verified in the Skia
         render path — False in Compact), so the existing #Nav.IsPaneOpen consumers and the
         SetRailPaneCompact feed keep working untouched. ExpandedModeThresholdWidth pins the single
         design rail breakpoint (1280). CompactModeThresholdWidth=0 makes the rail a clean TWO-state
         control at every width — Compact below 1280, Expanded at/above — so FA's third "LeftMinimal"
         state (a hidden hamburger pane) is never reachable: the rail is never hidden, only compacted
         (card 3a keeps it always visible). The 1100 figure in the responsive table is the
         column-shed band edge (ColumnVisibilityPolicy), not a second rail state. Nav fills the
         window, so Auto measures WINDOW width, not the pane-relative content width (PR #28).
         NOTE ON TESTS: FA Auto re-evaluates its DisplayMode on a real size-CHANGE / render pass, which
         the plain headless-drawing harness (Lattice.App.Tests) does not run — there the pane stays
         Expanded regardless of width. The end-to-end collapse is therefore gated in the Skia render
         path (Lattice.VisualTests, ShellRailCollapseVisualTests); Lattice.App.Tests pins the adaptive
         CONFIG that makes it collapse. -->
    <ui:FANavigationView x:Name="Nav" x:FieldModifier="public"
                       IsVisible="{Binding HasHosts}"
                       PaneDisplayMode="Auto"
                       ExpandedModeThresholdWidth="1280"
                       CompactModeThresholdWidth="0"
                       OpenPaneLength="260" CompactPaneLength="48"
                       IsSettingsVisible="False"
                       IsBackButtonVisible="False"
                       SelectionChanged="OnNavSelectionChanged">
      <ui:FANavigationView.MenuItems>
        <ui:FANavigationViewItem x:Name="NavTasks" Tag="0">
          <ui:FANavigationViewItem.Content>
            <DockPanel LastChildFill="False">
              <TextBlock Text="{x:Static loc:Strings.NavTasks}" DockPanel.Dock="Left" VerticalAlignment="Center" />
              <TextBlock Text="{Binding TasksCount}" FontSize="12" DockPanel.Dock="Right"
                         VerticalAlignment="Center" IsVisible="{Binding HasTasksCount}"
                         Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
            </DockPanel>
          </ui:FANavigationViewItem.Content>
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconTaskListSquareLtrRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavProjects" Content="{x:Static loc:Strings.NavProjects}" Tag="1">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconGridRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavTransfers" Tag="2">
          <ui:FANavigationViewItem.Content>
            <DockPanel LastChildFill="False">
              <TextBlock Text="{x:Static loc:Strings.NavTransfers}" DockPanel.Dock="Left" VerticalAlignment="Center" />
              <TextBlock Text="{Binding TransfersCount}" FontSize="12" DockPanel.Dock="Right"
                         VerticalAlignment="Center" IsVisible="{Binding HasTransfersCount}"
                         Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
            </DockPanel>
          </ui:FANavigationViewItem.Content>
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconArrowSwapRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavEventLog" Content="{x:Static loc:Strings.NavEventLog}" Tag="3">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconDocumentTextRegular}" />
          </ui:FANavigationViewItem.IconSource>
          <ui:FANavigationViewItem.InfoBadge>
            <ui:FAInfoBadge Value="{Binding EventLogUnread}" IsVisible="{Binding HasEventLogUnread}" />
          </ui:FANavigationViewItem.InfoBadge>
        </ui:FANavigationViewItem>
      </ui:FANavigationView.MenuItems>

      <ui:FANavigationView.PaneFooter>
        <StackPanel Margin="4,8,4,0">
          <DockPanel Margin="12,0,8,4">
            <Button DockPanel.Dock="Right" Padding="4" Background="Transparent"
                    Command="{Binding RequestAddHostCommand}"
                    ToolTip.Tip="{x:Static loc:Strings.HostsAddTooltip}">
              <PathIcon Data="{StaticResource IconAddRegular}" Width="12" Height="12" />
            </Button>
            <!-- List/group toggle: visible only while auto-grouping is in effect or a manual
                 override is active (decisions §4). Docked right, left of the "+" button. -->
            <Button DockPanel.Dock="Right" x:Name="RailGroupToggle" Padding="4" Background="Transparent"
                    Command="{Binding ToggleRailGroupingCommand}"
                    IsVisible="{Binding ShowRailToggle}"
                    ToolTip.Tip="{x:Static loc:Strings.RailGroupToggleTooltip}">
              <PathIcon Data="{StaticResource IconGroupListRegular}" Width="12" Height="12" />
            </Button>
            <!-- Design §Responsive: the 48px compact rail shows host state icons only;
                 names/subtext live in tooltips. Text elements follow the pane state. -->
            <TextBlock x:Name="HostsHeader" Text="{x:Static loc:Strings.HostsHeader}" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       IsVisible="{Binding #Nav.IsPaneOpen}"
                       Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
          </DockPanel>
          <ListBox x:Name="HostList" x:FieldModifier="public" Classes="hostRail"
                   Background="Transparent"
                   ItemsSource="{Binding RailEntries}"
                   SelectedItem="{Binding SelectedRailEntry, Mode=TwoWay}"
                   Tapped="OnHostRailTapped"
                   SelectionChanged="OnHostRailSelectionChanged">
            <ListBox.DataTemplates>
              <DataTemplate x:DataType="vm:AllHostsRailItemViewModel">
                <DockPanel Height="{StaticResource LatticeHostItemHeight}"
                           ToolTip.Tip="{Binding Tooltip}" Background="Transparent">
                  <Panel DockPanel.Dock="Left" Width="24" VerticalAlignment="Center">
                    <PathIcon Width="16" Height="16"
                              Data="{StaticResource IconAppsListRegular}"
                              Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                  </Panel>
                  <StackPanel x:Name="AllHostsText" VerticalAlignment="Center" Margin="4,0,0,0"
                              IsVisible="{Binding #Nav.IsPaneOpen}">
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Subtext}" FontSize="11"
                               Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                  </StackPanel>
                </DockPanel>
              </DataTemplate>
              <DataTemplate x:DataType="vm:HostRailItemViewModel">
                <!-- Height is the shell's mode-aware HostRowHeight (36 px inside a status group,
                     40 px flat/single) — rendering only; the RailLayoutPolicy fit math still
                     counts 40 px flat rows. -->
                <DockPanel Height="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).HostRowHeight}"
                           ToolTip.Tip="{Binding Tooltip}" Background="Transparent">
                  <!-- The menu lives on THIS template only, so the All-hosts sentinel and
                       group headers never get one (design 3b). Commands live on ShellViewModel;
                       the window does the dialog/test/confirm work. -->
                  <DockPanel.ContextFlyout>
                    <!-- Run-mode / snooze items (M3 PR H, DI-4) bind to the ROW VM's
                         own SetRunModeCommand: the ContextFlyout inherits the host
                         row's DataContext, so no $parent hop is needed (unlike the
                         Edit/Test/Remove items, whose commands live on the shell).
                         DI-3: the command's CanExecute gates each item on Connected.
                         Separators are MenuItem Header="-" — a raw <Separator/> silently
                         no-ops in a MenuFlyout (avalonia-menu-context-facts). -->
                    <MenuFlyout>
                      <MenuItem Header="{x:Static loc:Strings.HostMenuEdit}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).EditHostCommand}"
                                CommandParameter="{Binding HostId}">
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconEditRegular}" Width="16" Height="16" />
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="{x:Static loc:Strings.HostMenuTest}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).TestHostCommand}"
                                CommandParameter="{Binding HostId}">
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconPlugConnectedRegular}" Width="16" Height="16" />
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="-" />
                      <!-- Mode leaves are radios (design PR H, S2): GroupName per lane,
                           IsChecked reflects the host's PERMANENT mode (OneWay — the daemon
                           owns the value; the command drives the change and the next poll
                           re-checks). EnumMatchConverter matches the RunMode against the
                           parameter name. -->
                      <MenuItem Header="{x:Static loc:Strings.HostMenuRunModes}">
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconPlaySettingsRegular}" Width="16" Height="16" />
                        </MenuItem.Icon>
                        <MenuItem Header="{x:Static loc:Strings.HostMenuLaneCpu}">
                          <MenuItem.Icon>
                            <PathIcon Data="{StaticResource IconDeveloperBoardRegular}" Width="16" Height="16" />
                          </MenuItem.Icon>
                          <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeCpu"
                                    IsChecked="{Binding CpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="cpu:always" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeCpu"
                                    IsChecked="{Binding CpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="cpu:auto" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeCpu"
                                    IsChecked="{Binding CpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="cpu:never" />
                        </MenuItem>
                        <MenuItem Header="{x:Static loc:Strings.HostMenuLaneGpu}">
                          <MenuItem.Icon>
                            <PathIcon Data="{StaticResource IconDeveloperBoardLightningRegular}" Width="16" Height="16" />
                          </MenuItem.Icon>
                          <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeGpu"
                                    IsChecked="{Binding GpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="gpu:always" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeGpu"
                                    IsChecked="{Binding GpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="gpu:auto" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeGpu"
                                    IsChecked="{Binding GpuMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="gpu:never" />
                        </MenuItem>
                        <MenuItem Header="{x:Static loc:Strings.HostMenuLaneNetwork}">
                          <MenuItem.Icon>
                            <PathIcon Data="{StaticResource IconGlobeRegular}" Width="16" Height="16" />
                          </MenuItem.Icon>
                          <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeNet"
                                    IsChecked="{Binding NetworkMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="net:always" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeNet"
                                    IsChecked="{Binding NetworkMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="net:auto" />
                          <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeNet"
                                    IsChecked="{Binding NetworkMode, Converter={x:Static v:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                                    Command="{Binding SetRunModeCommand}" CommandParameter="net:never" />
                        </MenuItem>
                      </MenuItem>
                      <MenuItem Header="{x:Static loc:Strings.HostMenuSnooze}">
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconSnoozeRegular}" Width="16" Height="16" />
                        </MenuItem.Icon>
                        <MenuItem Header="{x:Static loc:Strings.SnoozeFifteenMinutes}"
                                  Command="{Binding SetRunModeCommand}" CommandParameter="snooze:15" />
                        <MenuItem Header="{x:Static loc:Strings.SnoozeOneHour}"
                                  Command="{Binding SetRunModeCommand}" CommandParameter="snooze:60" />
                        <MenuItem Header="{x:Static loc:Strings.SnoozeFourHours}"
                                  Command="{Binding SetRunModeCommand}" CommandParameter="snooze:240" />
                      </MenuItem>
                      <MenuItem Header="{x:Static loc:Strings.HostMenuResume}"
                                IsVisible="{Binding IsSnoozed}"
                                Command="{Binding SetRunModeCommand}" CommandParameter="resume">
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconPlayRegular}" Width="16" Height="16" />
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="-" />
                      <MenuItem Header="{x:Static loc:Strings.HostMenuRemove}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).RemoveHostCommand}"
                                CommandParameter="{Binding HostId}"
                                Foreground="{DynamicResource LatticeDangerFgBrush}">
                        <!-- Danger fg on the icon too (contract S2): the item Foreground is
                             inherited, but PathIcon.Foreground is set explicitly to be sure. -->
                        <MenuItem.Icon>
                          <PathIcon Data="{StaticResource IconDeleteRegular}" Width="16" Height="16"
                                    Foreground="{DynamicResource LatticeDangerFgBrush}" />
                        </MenuItem.Icon>
                      </MenuItem>
                    </MenuFlyout>
                  </DockPanel.ContextFlyout>
                  <Panel DockPanel.Dock="Left" Width="24" VerticalAlignment="Center">
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsConnected}"
                              Data="{StaticResource IconCheckmarkCircleRegular}"
                              Foreground="{DynamicResource LatticeSuccessBrush}" />
                    <PathIcon Classes.spin="{Binding IsConnecting}" Width="16" Height="16" IsVisible="{Binding IsConnecting}"
                              Data="{StaticResource IconArrowSyncRegular}"
                              Foreground="{DynamicResource LatticeAccentBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsRetrying}"
                              Data="{StaticResource IconArrowClockwiseRegular}"
                              Foreground="{DynamicResource LatticeWarningFgBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsUnreachable}"
                              Data="{StaticResource IconDismissCircleRegular}"
                              Foreground="{DynamicResource LatticeDangerFgBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsAuthFailed}"
                              Data="{StaticResource IconKeyRegular}"
                              Foreground="{DynamicResource LatticeDangerFgBrush}" />
                  </Panel>
                  <!-- Snooze pill (M3 PR H, S1). Two forms of one element, right-docked,
                       shown only while snoozed AND the pane is open (the 48px compact rail
                       shows the state icon only; the tooltip carries the snooze time there).
                       Form A = time pill (default); Form B = 20×20 icon chip (degraded when
                       the host text needs the room — RunModePillPolicy). Both lead with the
                       pause glyph so they read as one element; only one is visible per row. -->
                  <!-- Form A — time pill -->
                  <Border DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0"
                          Padding="6,2" CornerRadius="{StaticResource LatticeControlRadius}"
                          Background="{DynamicResource LatticeWarningTintBrush}"
                          BorderBrush="{DynamicResource LatticeWarningInfoBarBorderBrush}" BorderThickness="1">
                    <Border.IsVisible>
                      <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="PillShowsTime" />
                        <Binding Path="#Nav.IsPaneOpen" />
                      </MultiBinding>
                    </Border.IsVisible>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <PathIcon Width="10" Height="10" VerticalAlignment="Center"
                                Data="{StaticResource IconPauseRegular}"
                                Foreground="{DynamicResource LatticeWarningFgBrush}" />
                      <!-- tnum so the minutes don't jitter the pill width as they tick. -->
                      <TextBlock Text="{Binding SnoozedUntilTimeText}" FontSize="11" FontFeatures="+tnum"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource LatticeWarningFgBrush}" />
                    </StackPanel>
                  </Border>
                  <!-- Form B — icon chip (degraded) -->
                  <Border DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0"
                          Width="20" Height="20" CornerRadius="{StaticResource LatticeControlRadius}"
                          Background="{DynamicResource LatticeWarningTintBrush}"
                          BorderBrush="{DynamicResource LatticeWarningInfoBarBorderBrush}" BorderThickness="1">
                    <Border.IsVisible>
                      <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="PillShowsChip" />
                        <Binding Path="#Nav.IsPaneOpen" />
                      </MultiBinding>
                    </Border.IsVisible>
                    <PathIcon Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="{StaticResource IconPauseRegular}"
                              Foreground="{DynamicResource LatticeWarningFgBrush}" />
                  </Border>
                  <StackPanel x:Name="HostText" VerticalAlignment="Center" Margin="4,0,0,0"
                              IsVisible="{Binding #Nav.IsPaneOpen}">
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                    <TextBlock Text="{Binding SubtextDisplay}" FontSize="11"
                               Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                  </StackPanel>
                </DockPanel>
              </DataTemplate>
              <DataTemplate x:DataType="vm:GroupHeaderRailItemViewModel">
                <!-- Hidden in the 48px compact pane (decisions §5: "compact shows individual host
                     icons"). Otherwise an Attention header — text hidden, chevron hidden because it
                     is not collapsible — would render a blank 28px row above its host icons. -->
                <DockPanel Height="{StaticResource LatticeRowHeightCompact}" Background="Transparent"
                           IsVisible="{Binding #Nav.IsPaneOpen}">
                  <PathIcon DockPanel.Dock="Left" Width="12" Height="12" Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsCollapsible}"
                            Data="{StaticResource IconChevronRightRegular}"
                            Foreground="{DynamicResource LatticeTextSecondaryBrush}">
                    <PathIcon.RenderTransform>
                      <RotateTransform Angle="{Binding Expanded, Converter={x:Static v:TaskGridConverters.ChevronAngle}}" />
                    </PathIcon.RenderTransform>
                  </PathIcon>
                  <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center" Margin="6,0,0,0"
                             Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                </DockPanel>
              </DataTemplate>
            </ListBox.DataTemplates>
          </ListBox>
        </StackPanel>
      </ui:FANavigationView.PaneFooter>

      <ui:FANavigationView.FooterMenuItems>
        <ui:FANavigationViewItem x:Name="NavSettings" Content="{x:Static loc:Strings.NavSettings}" Tag="settings">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconSettingsRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
      </ui:FANavigationView.FooterMenuItems>

      <!-- View switch (design card 1h / spec §11): the incoming page fades in while rising
           8px, the outgoing fades out, over 150 ms decelerateMid. TransitioningContentControl
           assigns Content synchronously the moment CurrentPage changes, so the page's data is
           bound before the transition plays — the motion is cosmetic and never delays a data
           update (value-first).
           Deliberately NOT painted opaque: a command bar lives at the top of each hosted view, and
           under Mica it goes transparent to reveal the material — an opaque host behind it would
           reveal the canvas instead of the window/Mica (Codex P2, PR #99). Content opacity is owned
           per-view by each page's ContentRegion (everything below the command bar). -->
      <TransitioningContentControl x:Name="ViewHost" x:FieldModifier="public"
                                   Content="{Binding CurrentPage}">
        <TransitioningContentControl.PageTransition>
          <inf:FadeSlidePageTransition />
        </TransitioningContentControl.PageTransition>
        <TransitioningContentControl.DataTemplates>
          <DataTemplate DataType="vm:PlaceholderViewModel">
            <v:PlaceholderView />
          </DataTemplate>
          <DataTemplate DataType="vm:SettingsViewModel">
            <v:SettingsView />
          </DataTemplate>
          <DataTemplate DataType="vm:TasksViewModel">
            <v:TasksView />
          </DataTemplate>
          <DataTemplate DataType="vm:ProjectsViewModel">
            <v:ProjectsView />
          </DataTemplate>
          <DataTemplate DataType="vm:TransfersViewModel">
            <v:TransfersView />
          </DataTemplate>
          <DataTemplate DataType="vm:EventLogViewModel">
            <v:EventLogView />
          </DataTemplate>
        </TransitioningContentControl.DataTemplates>
      </TransitioningContentControl>
    </ui:FANavigationView>
  </Panel>
</Window>
