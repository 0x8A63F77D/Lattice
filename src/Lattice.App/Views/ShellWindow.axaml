<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:Lattice.App.ViewModels"
        xmlns:v="using:Lattice.App.Views"
        xmlns:loc="using:Lattice.App.Localization"
        x:Class="Lattice.App.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        Title="{x:Static loc:Strings.AppTitle}"
        Icon="/Assets/lattice.ico"
        Width="1280" Height="800" MinWidth="1000" MinHeight="700"
        TransparencyLevelHint="Mica, None"
        Background="{DynamicResource LatticeCanvasBrush}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding SelectViewCommand}" CommandParameter="0" />
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding SelectViewCommand}" CommandParameter="1" />
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding SelectViewCommand}" CommandParameter="2" />
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding SelectViewCommand}" CommandParameter="3" />
  </Window.KeyBindings>

  <Window.Styles>
    <!-- The only allowed looping animation: Connecting spinner, 1.5 s/rev linear -->
    <Style Selector="PathIcon.spin">
      <Setter Property="RenderTransform">
        <RotateTransform Angle="0" />
      </Setter>
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Selected host rail entry: brand tint + accent pill (design 1c) -->
    <Style Selector="ListBox.hostRail ListBoxItem">
      <Setter Property="Padding" Value="8,0" />
      <!-- Each rail container sizes to its template's explicit DockPanel height (28 header /
           36 grouped host / 40 flat & All-hosts). A 40px MinHeight would floor the shorter
           28/36px design-3a rows; the compact group-header collapse also needs 0 here. -->
      <Setter Property="MinHeight" Value="0" />
      <!-- The theme's ListBoxItem MinWidth (88) overflows the 48px compact rail:
           layout centers the oversized item at a negative offset and the state
           icon renders half-clipped at the pane edge. Rail entries stretch to
           whatever width the pane gives them. -->
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="CornerRadius" Value="{StaticResource LatticeControlRadius}" />
    </Style>
    <!-- FluentAvalonia's ListBoxItem template insets its ContentPresenter by 2px on every
         side. That 4px of vertical chrome would make every rail row 4px taller than its
         template's explicit DockPanel height (design 3a rows are 28 header / 36 grouped host /
         40 flat — the RENDERED row height, card 1g), and would leave a 4px ghost row where a
         compact group-header collapses to zero content. Zero the inset so the container height
         equals the DockPanel height; the selection tint then fills the full row. -->
    <Style Selector="ListBox.hostRail ListBoxItem /template/ ContentPresenter">
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="ListBox.hostRail ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource LatticeSelectedTintBrush}" />
    </Style>
    <!-- Host-row context menu items: 32px rows (design 3b). -->
    <Style Selector="MenuFlyoutPresenter MenuItem">
      <Setter Property="MinHeight" Value="32" />
    </Style>
  </Window.Styles>

  <Panel>
    <v:FirstRunView x:Name="FirstRun" x:FieldModifier="public" IsVisible="{Binding !HasHosts}" />

    <ui:FANavigationView x:Name="Nav" x:FieldModifier="public"
                       IsVisible="{Binding HasHosts}"
                       PaneDisplayMode="Left"
                       OpenPaneLength="260" CompactPaneLength="48"
                       IsSettingsVisible="False"
                       IsBackButtonVisible="False"
                       SelectionChanged="OnNavSelectionChanged">
      <ui:FANavigationView.MenuItems>
        <ui:FANavigationViewItem x:Name="NavTasks" Tag="0">
          <ui:FANavigationViewItem.Content>
            <DockPanel LastChildFill="False">
              <TextBlock Text="{x:Static loc:Strings.NavTasks}" DockPanel.Dock="Left" VerticalAlignment="Center" />
              <TextBlock Text="{Binding TasksCount}" FontSize="12" DockPanel.Dock="Right"
                         VerticalAlignment="Center" IsVisible="{Binding HasTasksCount}"
                         Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
            </DockPanel>
          </ui:FANavigationViewItem.Content>
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconTaskListSquareLtrRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavProjects" Content="{x:Static loc:Strings.NavProjects}" Tag="1">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconGridRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavTransfers" Tag="2">
          <ui:FANavigationViewItem.Content>
            <DockPanel LastChildFill="False">
              <TextBlock Text="{x:Static loc:Strings.NavTransfers}" DockPanel.Dock="Left" VerticalAlignment="Center" />
              <TextBlock Text="{Binding TransfersCount}" FontSize="12" DockPanel.Dock="Right"
                         VerticalAlignment="Center" IsVisible="{Binding HasTransfersCount}"
                         Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
            </DockPanel>
          </ui:FANavigationViewItem.Content>
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconArrowSwapRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
        <ui:FANavigationViewItem x:Name="NavEventLog" Content="{x:Static loc:Strings.NavEventLog}" Tag="3">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconDocumentTextRegular}" />
          </ui:FANavigationViewItem.IconSource>
          <ui:FANavigationViewItem.InfoBadge>
            <ui:FAInfoBadge Value="{Binding EventLogUnread}" IsVisible="{Binding HasEventLogUnread}" />
          </ui:FANavigationViewItem.InfoBadge>
        </ui:FANavigationViewItem>
      </ui:FANavigationView.MenuItems>

      <ui:FANavigationView.PaneFooter>
        <StackPanel Margin="4,8,4,0">
          <DockPanel Margin="12,0,8,4">
            <Button DockPanel.Dock="Right" Padding="4" Background="Transparent"
                    Command="{Binding RequestAddHostCommand}"
                    ToolTip.Tip="{x:Static loc:Strings.HostsAddTooltip}">
              <PathIcon Data="{StaticResource IconAddRegular}" Width="12" Height="12" />
            </Button>
            <!-- List/group toggle: visible only while auto-grouping is in effect or a manual
                 override is active (decisions §4). Docked right, left of the "+" button. -->
            <Button DockPanel.Dock="Right" x:Name="RailGroupToggle" Padding="4" Background="Transparent"
                    Command="{Binding ToggleRailGroupingCommand}"
                    IsVisible="{Binding ShowRailToggle}"
                    ToolTip.Tip="{x:Static loc:Strings.RailGroupToggleTooltip}">
              <PathIcon Data="{StaticResource IconGroupListRegular}" Width="12" Height="12" />
            </Button>
            <!-- Design §Responsive: the 48px compact rail shows host state icons only;
                 names/subtext live in tooltips. Text elements follow the pane state. -->
            <TextBlock x:Name="HostsHeader" Text="{x:Static loc:Strings.HostsHeader}" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       IsVisible="{Binding #Nav.IsPaneOpen}"
                       Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
          </DockPanel>
          <ListBox x:Name="HostList" x:FieldModifier="public" Classes="hostRail"
                   Background="Transparent"
                   ItemsSource="{Binding RailEntries}"
                   SelectedItem="{Binding SelectedRailEntry, Mode=TwoWay}"
                   SelectionChanged="OnHostSelectionChanged">
            <ListBox.DataTemplates>
              <DataTemplate x:DataType="vm:AllHostsRailItemViewModel">
                <DockPanel Height="{StaticResource LatticeHostItemHeight}"
                           ToolTip.Tip="{Binding Tooltip}" Background="Transparent">
                  <Panel DockPanel.Dock="Left" Width="24" VerticalAlignment="Center">
                    <PathIcon Width="16" Height="16"
                              Data="{StaticResource IconAppsListRegular}"
                              Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                  </Panel>
                  <StackPanel x:Name="AllHostsText" VerticalAlignment="Center" Margin="4,0,0,0"
                              IsVisible="{Binding #Nav.IsPaneOpen}">
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Subtext}" FontSize="11"
                               Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                  </StackPanel>
                </DockPanel>
              </DataTemplate>
              <DataTemplate x:DataType="vm:HostRailItemViewModel">
                <!-- Height is the shell's mode-aware HostRowHeight (36 px inside a status group,
                     40 px flat/single) — rendering only; the RailLayoutPolicy fit math still
                     counts 40 px flat rows. -->
                <DockPanel Height="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).HostRowHeight}"
                           ToolTip.Tip="{Binding Tooltip}" Background="Transparent">
                  <!-- The menu lives on THIS template only, so the All-hosts sentinel and
                       group headers never get one (design 3b). Commands live on ShellViewModel;
                       the window does the dialog/test/confirm work. -->
                  <DockPanel.ContextFlyout>
                    <MenuFlyout>
                      <MenuItem Header="{x:Static loc:Strings.HostMenuEdit}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).EditHostCommand}"
                                CommandParameter="{Binding HostId}" />
                      <MenuItem Header="{x:Static loc:Strings.HostMenuTest}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).TestHostCommand}"
                                CommandParameter="{Binding HostId}" />
                      <MenuItem Header="{x:Static loc:Strings.HostMenuRemove}"
                                Command="{Binding $parent[ListBox].((vm:ShellViewModel)DataContext).RemoveHostCommand}"
                                CommandParameter="{Binding HostId}"
                                Foreground="{DynamicResource LatticeDangerFgBrush}" />
                    </MenuFlyout>
                  </DockPanel.ContextFlyout>
                  <Panel DockPanel.Dock="Left" Width="24" VerticalAlignment="Center">
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsConnected}"
                              Data="{StaticResource IconCheckmarkCircleRegular}"
                              Foreground="{DynamicResource LatticeSuccessBrush}" />
                    <PathIcon Classes.spin="{Binding IsConnecting}" Width="16" Height="16" IsVisible="{Binding IsConnecting}"
                              Data="{StaticResource IconArrowSyncRegular}"
                              Foreground="{DynamicResource LatticeAccentBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsRetrying}"
                              Data="{StaticResource IconArrowClockwiseRegular}"
                              Foreground="{DynamicResource LatticeWarningFgBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsUnreachable}"
                              Data="{StaticResource IconDismissCircleRegular}"
                              Foreground="{DynamicResource LatticeDangerFgBrush}" />
                    <PathIcon Width="16" Height="16" IsVisible="{Binding IsAuthFailed}"
                              Data="{StaticResource IconKeyRegular}"
                              Foreground="{DynamicResource LatticeDangerFgBrush}" />
                  </Panel>
                  <StackPanel x:Name="HostText" VerticalAlignment="Center" Margin="4,0,0,0"
                              IsVisible="{Binding #Nav.IsPaneOpen}">
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               Foreground="{DynamicResource LatticeTextPrimaryBrush}" />
                    <TextBlock Text="{Binding SubtextDisplay}" FontSize="11"
                               Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                  </StackPanel>
                </DockPanel>
              </DataTemplate>
              <DataTemplate x:DataType="vm:GroupHeaderRailItemViewModel">
                <!-- Hidden in the 48px compact pane (decisions §5: "compact shows individual host
                     icons"). Otherwise an Attention header — text hidden, chevron hidden because it
                     is not collapsible — would render a blank 28px row above its host icons. -->
                <DockPanel Height="{StaticResource LatticeRowHeightCompact}" Background="Transparent"
                           IsVisible="{Binding #Nav.IsPaneOpen}">
                  <PathIcon DockPanel.Dock="Left" Width="12" Height="12" Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsCollapsible}"
                            Data="{StaticResource IconChevronRightRegular}"
                            Foreground="{DynamicResource LatticeTextSecondaryBrush}">
                    <PathIcon.RenderTransform>
                      <RotateTransform Angle="{Binding Expanded, Converter={x:Static v:TaskGridConverters.ChevronAngle}}" />
                    </PathIcon.RenderTransform>
                  </PathIcon>
                  <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center" Margin="6,0,0,0"
                             Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
                </DockPanel>
              </DataTemplate>
            </ListBox.DataTemplates>
          </ListBox>
        </StackPanel>
      </ui:FANavigationView.PaneFooter>

      <ui:FANavigationView.FooterMenuItems>
        <ui:FANavigationViewItem x:Name="NavSettings" Content="{x:Static loc:Strings.NavSettings}" Tag="settings">
          <ui:FANavigationViewItem.IconSource>
            <ui:FAPathIconSource Data="{StaticResource IconSettingsRegular}" />
          </ui:FANavigationViewItem.IconSource>
        </ui:FANavigationViewItem>
      </ui:FANavigationView.FooterMenuItems>

      <ContentControl Content="{Binding CurrentPage}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:PlaceholderViewModel">
            <v:PlaceholderView />
          </DataTemplate>
          <DataTemplate DataType="vm:SettingsViewModel">
            <v:SettingsView />
          </DataTemplate>
          <DataTemplate DataType="vm:TasksViewModel">
            <v:TasksView />
          </DataTemplate>
          <DataTemplate DataType="vm:ProjectsViewModel">
            <v:ProjectsView />
          </DataTemplate>
          <DataTemplate DataType="vm:TransfersViewModel">
            <v:TransfersView />
          </DataTemplate>
          <DataTemplate DataType="vm:EventLogViewModel">
            <v:EventLogView />
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>
    </ui:FANavigationView>
  </Panel>
</Window>
