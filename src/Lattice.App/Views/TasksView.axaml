<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Lattice.App.ViewModels"
             xmlns:views="using:Lattice.App.Views"
             xmlns:controls="using:Lattice.App.Controls"
             xmlns:loc="using:Lattice.App.Localization"
             x:Class="Lattice.App.Views.TasksView"
             x:DataType="vm:TasksViewModel">

  <UserControl.KeyBindings>
    <!-- F5 is a pure VM-command gesture, so it's declarative (the ShellWindow
         KeyBindings idiom); Ctrl+F needs imperative focus on a named control —
         a view-local concern, not a VM command — so it lives in OnKeyDown. -->
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
  </UserControl.KeyBindings>

  <UserControl.Styles>
    <!-- Row-class overrides (design §Task 11): suspended dimming.
         The at-risk row tint now lives centrally in DataGridStyles.axaml
         (DataGrid.lattice DataGridRow.atRisk) alongside its :pointerover
         hover-keep, so it is not duplicated here. Selection tint intentionally
         wins when a row is both selected and at-risk (deferred design decision,
         resolved): the Deadline cell's warning icon still marks the risk, so
         nothing is lost. -->
    <Style Selector="DataGridRow.suspended">
      <Setter Property="Foreground" Value="{DynamicResource LatticeTextSecondaryBrush}" />
    </Style>
    <!-- Progress-fill Border: accent normally, disabled-gray for suspended tasks.
         The bound Width updates immediately (value-first); the 200 ms easyEase width
         transition is cosmetic and never gates the data (design card 1h / spec §11). -->
    <Style Selector="Border.progressFill">
      <Setter Property="Background" Value="{DynamicResource LatticeAccentBrush}" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.2">
            <DoubleTransition.Easing>
              <SplineEasing X1="0.33" Y1="0" X2="0.67" Y2="1" />
            </DoubleTransition.Easing>
          </DoubleTransition>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.progressFill.suspended">
      <Setter Property="Background" Value="{DynamicResource LatticeDisabledBrush}" />
    </Style>
    <!-- Deadline-cell text: SemiBold warning color when the row's deadline is at risk. -->
    <Style Selector="TextBlock.atRiskText">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource LatticeWarningFgBrush}" />
    </Style>
  </UserControl.Styles>

  <DockPanel>
    <!-- Command bar -->
    <Border x:Name="CommandBar" DockPanel.Dock="Top" Height="{StaticResource LatticeCommandBarHeight}"
            Background="{DynamicResource LatticeCommandBarSurfaceBrush}"
            BorderBrush="{DynamicResource LatticeStrokeSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel Margin="16,0" LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{x:Static loc:Strings.TasksTitle}" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource LatticeTextPrimaryBrush}" VerticalAlignment="Center" />
          <!-- M3 control ops on the selected row. DI-3: disabled (with a tooltip
               that must show on the disabled control) unless the row's host is
               Connected. DI-1(c): Abort sits behind a Separator so a suspend
               misclick can't land on the destructive op. -->
          <Button x:Name="SuspendButton" Content="{x:Static loc:Strings.Suspend}" Margin="8,0,0,0"
                  Command="{Binding SuspendSelectedCommand}"
                  ToolTip.Tip="{Binding ControlDisabledReason}" ToolTip.ShowOnDisabled="True" />
          <Button x:Name="ResumeButton" Content="{x:Static loc:Strings.Resume}"
                  Command="{Binding ResumeSelectedCommand}"
                  ToolTip.Tip="{Binding ControlDisabledReason}" ToolTip.ShowOnDisabled="True" />
          <Separator Margin="4,0" />
          <Button x:Name="AbortButton" Content="{x:Static loc:Strings.Abort}"
                  Command="{Binding AbortSelectedCommand}"
                  ToolTip.Tip="{Binding ControlDisabledReason}" ToolTip.ShowOnDisabled="True" />
          <Separator Margin="8,0" />
          <!-- "Computing" run-mode dropdown (M3 PR H, DI-4): host-level run modes /
               snooze for the SINGLE scoped host. Absent in All-hosts scope
               (HasScopedHost false → no fleet-wide run modes in M3). The MenuFlyout
               items bind to the scoped host row VM's SetRunModeCommand, reached via
               the pushed ScopedHost property so the popup tree resolves through the
               inherited view-model DataContext. -->
          <!-- Computing button (design PR H, S3): play_settings icon + label + chevron,
               32px tall centered in the 52px bar. -->
          <Button x:Name="ComputingButton" IsVisible="{Binding HasScopedHost}"
                  Height="32" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource IconPlaySettingsRegular}" Width="16" Height="16"
                        VerticalAlignment="Center" />
              <TextBlock Text="{x:Static loc:Strings.ComputingMenu}" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
              <PathIcon Data="{StaticResource IconChevronDownRegular}" Width="12" Height="12"
                        VerticalAlignment="Center" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout>
                <!-- Radios reflect the scoped host's PERMANENT mode (design PR H, S2/S3 —
                     identical to the rail menu, one spec two hosts). -->
                <MenuItem Header="{x:Static loc:Strings.HostMenuRunModes}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource IconPlaySettingsRegular}" Width="16" Height="16" />
                  </MenuItem.Icon>
                  <MenuItem Header="{x:Static loc:Strings.HostMenuLaneCpu}">
                    <MenuItem.Icon>
                      <PathIcon Data="{StaticResource IconDeveloperBoardRegular}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeCpu"
                              IsChecked="{Binding ScopedHost.CpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="cpu:always" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeCpu"
                              IsChecked="{Binding ScopedHost.CpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="cpu:auto" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeCpu"
                              IsChecked="{Binding ScopedHost.CpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="cpu:never" />
                  </MenuItem>
                  <MenuItem Header="{x:Static loc:Strings.HostMenuLaneGpu}">
                    <MenuItem.Icon>
                      <PathIcon Data="{StaticResource IconDeveloperBoardLightningRegular}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeGpu"
                              IsChecked="{Binding ScopedHost.GpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="gpu:always" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeGpu"
                              IsChecked="{Binding ScopedHost.GpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="gpu:auto" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeGpu"
                              IsChecked="{Binding ScopedHost.GpuMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="gpu:never" />
                  </MenuItem>
                  <MenuItem Header="{x:Static loc:Strings.HostMenuLaneNetwork}">
                    <MenuItem.Icon>
                      <PathIcon Data="{StaticResource IconGlobeRegular}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="{x:Static loc:Strings.RunModeAlways}" ToggleType="Radio" GroupName="RunModeNet"
                              IsChecked="{Binding ScopedHost.NetworkMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Always, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="net:always" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeAuto}" ToggleType="Radio" GroupName="RunModeNet"
                              IsChecked="{Binding ScopedHost.NetworkMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Auto, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="net:auto" />
                    <MenuItem Header="{x:Static loc:Strings.RunModeNever}" ToggleType="Radio" GroupName="RunModeNet"
                              IsChecked="{Binding ScopedHost.NetworkMode, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Never, Mode=OneWay}"
                              Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="net:never" />
                  </MenuItem>
                </MenuItem>
                <MenuItem Header="{x:Static loc:Strings.HostMenuSnooze}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource IconSnoozeRegular}" Width="16" Height="16" />
                  </MenuItem.Icon>
                  <MenuItem Header="{x:Static loc:Strings.SnoozeFifteenMinutes}"
                            Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="snooze:15" />
                  <MenuItem Header="{x:Static loc:Strings.SnoozeOneHour}"
                            Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="snooze:60" />
                  <MenuItem Header="{x:Static loc:Strings.SnoozeFourHours}"
                            Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="snooze:240" />
                </MenuItem>
                <MenuItem Header="{x:Static loc:Strings.HostMenuResume}"
                          IsVisible="{Binding ScopedHost.IsSnoozed}"
                          Command="{Binding ScopedHost.SetRunModeCommand}" CommandParameter="resume">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource IconPlayRegular}" Width="16" Height="16" />
                  </MenuItem.Icon>
                </MenuItem>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <Separator Margin="8,0" />
          <TextBox x:Name="FilterBox" x:FieldModifier="public" Width="220"
                   Text="{Binding FilterText, Mode=TwoWay}"
                   PlaceholderText="{x:Static loc:Strings.FilterPlaceholder}" />
          <!-- OpenOnPress: dropdown opens on mouse-down like native macOS popup buttons; stock
               Avalonia opens on release, which reads as click latency (issue #95, measured there). -->
          <ComboBox x:Name="StateFilterBox" SelectedIndex="0" SelectionChanged="OnStateFilterChanged"
                    views:ComboBoxPressOpenBehavior.OpenOnPress="True">
            <ComboBoxItem Content="{x:Static loc:Strings.StateAll}" />
            <ComboBoxItem Content="{x:Static loc:Strings.TaskStateRunning}" />
            <ComboBoxItem Content="{x:Static loc:Strings.TaskStateWaiting}" />
            <ComboBoxItem Content="{x:Static loc:Strings.TaskStateSuspended}" />
            <ComboBoxItem Content="{x:Static loc:Strings.TaskStateUploading}" />
          </ComboBox>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,8,0">
            <PathIcon Data="{StaticResource IconWarningFilled}" Width="12" Height="12"
                      Foreground="{DynamicResource LatticeWarningFgBrush}"
                      IsVisible="{Binding IsUpdateStale}" />
            <TextBlock Text="{Binding UpdatedText}" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource LatticeWarningFgBrush}"
                       IsVisible="{Binding IsUpdateStale}" />
            <TextBlock Text="{Binding UpdatedText}" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource LatticeTextSecondaryBrush}"
                       IsVisible="{Binding !IsUpdateStale}" />
          </StackPanel>
          <Button Padding="6" Background="Transparent" Command="{Binding RefreshCommand}"
                  ToolTip.Tip="{x:Static loc:Strings.RetryNow}">
            <PathIcon Data="{StaticResource IconArrowClockwiseRegular}" Width="14" Height="14" />
          </Button>
          <ToggleButton x:Name="DensityToggle" Padding="6" Background="Transparent"
                        IsChecked="{Binding IsCompact, Mode=TwoWay}">
            <PathIcon Data="{StaticResource IconTextLineSpacingRegular}" Width="14" Height="14" />
          </ToggleButton>
          <Button x:Name="OverflowButton" Padding="6" Background="Transparent">
            <PathIcon Data="{StaticResource IconMoreHorizontalRegular}" Width="14" Height="14" />
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="{x:Static loc:Strings.ColProject}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Project" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColApplication}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Application" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColProgress}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Progress" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColElapsed}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Elapsed" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColRemaining}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Remaining" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColDeadline}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="Deadline" IsChecked="True" Click="OnColumnVisibilityToggled" />
                <MenuItem Header="{x:Static loc:Strings.ColState}" ToggleType="CheckBox" StaysOpenOnClick="True"
                          Tag="State" IsChecked="True" Click="OnColumnVisibilityToggled" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- One opaque content region for EVERYTHING below the command bar (design: content is always
         opaque). Only the command bar stays transparent to reveal Mica; the InfoBar (whose margins
         would otherwise leak the material), the status bar, and the grid all sit on this canvas, so
         no non-command-bar gap can show through under Mica (Codex P2s, PR #99). -->
    <DockPanel x:Name="ContentRegion" Background="{DynamicResource LatticeCanvasBrush}">

    <!-- Status bar -->
    <controls:StatusBarControl DockPanel.Dock="Bottom"
                                LeftText="{Binding CountsText}"
                                WarningText="{Binding AtRiskText}"
                                RightText="{Binding PollingText}" />

    <!-- Grid + overlays -->
    <Panel>
      <!-- The grid binds RowsView (a DataGridCollectionView), not Rows: the VIEW owns display
           order (issue #86). The VM installs the default deadline order as a comparer sort
           description (null PropertyPath = no header arrow); a header click routes through the
           grid's own ProcessSort, which replaces it with the clicked column's SortMemberPath
           sort — flat grid, so the built-in FromPath machinery composes without the custom
           description subclass Projects' hierarchy needs. The source collection stays in
           reconcile-friendly order, so poll reorders never remove/reinsert a selected row. -->
      <DataGrid x:Name="Grid" x:FieldModifier="public" Classes="lattice" Classes.compact="{Binding IsCompact}"
                ItemsSource="{Binding RowsView}" IsReadOnly="True" CanUserSortColumns="True"
                SelectedItem="{Binding SelectedRow, Mode=TwoWay}">
        <!-- Row context menu (M3): same commands as the command bar, acting on
             the selection; the code-behind moves selection to the row under a
             right-click first, so the menu never targets a stale row. -->
        <DataGrid.ContextFlyout>
          <MenuFlyout>
            <MenuItem Header="{x:Static loc:Strings.Suspend}" Command="{Binding SuspendSelectedCommand}" />
            <MenuItem Header="{x:Static loc:Strings.Resume}" Command="{Binding ResumeSelectedCommand}" />
            <!-- DI-1(c) misclick distance applies here too (Codex R1 P3). The
                 divider is a raw <Separator/> — the first-class MenuFlyout separator
                 (FA 3.0.1 themes {x:Type Separator} with its own thin metrics). The
                 old Header="-" pseudo-item kept a full MenuItem's MinHeight and
                 inflated the gap around the line (#155); a Separator is not a MenuItem
                 so it collapses to the correct ~1px rule. -->
            <Separator />
            <MenuItem Header="{x:Static loc:Strings.Abort}" Command="{Binding AbortSelectedCommand}"
                      Foreground="{DynamicResource LatticeDangerFgBrush}" />
          </MenuFlyout>
        </DataGrid.ContextFlyout>
        <DataGrid.Columns>
          <!-- Text-column bindings carry an explicit DataType: the ItemsSource is RowsView (a
               non-generic DataGridCollectionView), so the compiler can no longer infer the row
               type from the collection (Projects-column idiom). -->
          <DataGridTextColumn Header="{x:Static loc:Strings.ColProject}" Tag="Project"
                               Binding="{CompiledBinding Data.Project, DataType=vm:TaskRow}" Width="108" MinWidth="108" />
          <DataGridTextColumn Header="{x:Static loc:Strings.ColApplication}" Tag="Application"
                               Binding="{CompiledBinding Data.Application, DataType=vm:TaskRow}" Width="118" MinWidth="118" />
          <!-- Fixed width (NOT a star column): a star (*) column makes the DataGrid fit-to-width,
               which pins the grid total to the viewport — it can never overflow, so horizontal
               scroll never engages and dragging a column just reshuffles space between columns
               (owner Finding A round 2: "总宽度限制死了…列在互相共享窗口宽度"). Every column is
               fixed instead: when the columns exceed the viewport (narrow window or a column
               dragged wider) the grid overflows into a working h-scrollbar; when they fit, the
               DataGridFillerColumn takes the trailing space (native Task-Manager idiom). -->
          <!-- SortMemberPath: a template column has no Binding for the DataGrid to derive a sort
               key from (unlike the text columns), so it is unsortable unless given an explicit path.
               Point each at the underlying COMPARABLE property so sorting uses the real value, not
               the formatted display string (e.g. Fraction, not "34%"; Deadline, not its text). -->
          <DataGridTemplateColumn Header="{x:Static loc:Strings.ColTask}" Tag="Task"
                                   Width="230" MinWidth="230" SortMemberPath="Data.Name">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:TaskRow">
                <TextBlock Text="{Binding Data.Name}" VerticalAlignment="Center"
                           TextTrimming="PrefixCharacterEllipsis" ToolTip.Tip="{Binding Data.Name}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{x:Static loc:Strings.ColProgress}" Tag="Progress" Width="112" MinWidth="112"
                                   SortMemberPath="Data.Fraction">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:TaskRow">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Border Width="56" Height="3" CornerRadius="2" Background="{DynamicResource LatticeStrokeBrush}">
                    <!-- SnapOnRebind stops the 200ms width transition from animating when this
                         virtualized cell is recycled to another row (sort/scroll/filter) — it would
                         otherwise slide from the previous row's progress (Codex P2 PR #103). -->
                    <Border Classes="progressFill" Classes.suspended="{Binding Data.IsSuspended}"
                            HorizontalAlignment="Left" Height="3" CornerRadius="2"
                            views:ProgressFillBehavior.SnapOnRebind="True"
                            Width="{Binding Data.Fraction, Converter={x:Static views:FractionToWidthConverter.Instance}}" />
                  </Border>
                  <TextBlock Text="{Binding Data.PercentText}" FontSize="12" Classes="numeric" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <!-- SortMemberPath overrides the (text) binding for sorting so these sort by the raw
               duration in seconds, not the formatted string ("10m" would sort before "9m"). -->
          <DataGridTextColumn Header="{x:Static loc:Strings.ColElapsed}" Tag="Elapsed"
                               Binding="{CompiledBinding Data.ElapsedText, DataType=vm:TaskRow}" Width="68" MinWidth="68"
                               CellStyleClasses="numericCell" SortMemberPath="Data.ElapsedSeconds" />
          <DataGridTextColumn Header="{x:Static loc:Strings.ColRemaining}" Tag="Remaining"
                               Binding="{CompiledBinding Data.RemainingText, DataType=vm:TaskRow}" Width="74" MinWidth="74"
                               CellStyleClasses="numericCell" SortMemberPath="Data.RemainingSeconds" />
          <DataGridTemplateColumn Header="{x:Static loc:Strings.ColDeadline}" Tag="Deadline" Width="100" MinWidth="100"
                                   SortMemberPath="Data.Deadline">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:TaskRow">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <PathIcon Width="10" Height="10" Data="{StaticResource IconWarningFilled}"
                            IsVisible="{Binding Data.IsDeadlineAtRisk}"
                            Foreground="{DynamicResource LatticeWarningFgBrush}" />
                  <TextBlock Text="{Binding Data.DeadlineText}" FontSize="12" Classes="numeric"
                             Classes.atRiskText="{Binding Data.IsDeadlineAtRisk}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{x:Static loc:Strings.ColState}" Tag="State" Width="112" MinWidth="112"
                                   SortMemberPath="Data.StateKind">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:TaskRow">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Panel Width="12" Height="12">
                    <PathIcon Width="12" Height="12" Data="{StaticResource IconPlayRegular}"
                              Foreground="{DynamicResource LatticeSuccessBrush}"
                              IsVisible="{Binding Data.StateKind, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Running}" />
                    <PathIcon Width="12" Height="12" Data="{StaticResource IconClockRegular}"
                              Foreground="{DynamicResource LatticeNeutralFgBrush}"
                              IsVisible="{Binding Data.StateKind, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Waiting}" />
                    <PathIcon Width="12" Height="12" Data="{StaticResource IconPauseRegular}"
                              Foreground="{DynamicResource LatticeTextSecondaryBrush}"
                              IsVisible="{Binding Data.StateKind, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Suspended}" />
                    <PathIcon Width="12" Height="12" Data="{StaticResource IconArrowUploadRegular}"
                              Foreground="{DynamicResource LatticeAccentBrush}"
                              IsVisible="{Binding Data.StateKind, Converter={x:Static views:EnumMatchConverter.Instance}, ConverterParameter=Uploading}" />
                  </Panel>
                  <TextBlock Text="{Binding Data.StateText}" FontSize="12" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="{x:Static loc:Strings.ColHost}" Tag="Host"
                               Binding="{CompiledBinding Data.Host, DataType=vm:TaskRow}" Width="76" MinWidth="76"
                               IsVisible="{Binding IsAllHostsScope}" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Loading overlay. dataOverlay (issue #88): inset below the column header. -->
      <Border Classes="dataOverlay" Background="{DynamicResource LatticeSurfaceBrush}" IsVisible="{Binding IsLoading}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Width="220">
          <!-- IsActive MUST track IsLoading: the ring's composition animation ignores IsVisible —
               once shown it re-registers for every frame forever, keeping the dispatcher non-idle
               and starving pointer input to the 1 s InputStarvationTimeout ceiling (issue #95). -->
          <ui:FAProgressRing Width="32" Height="32" HorizontalAlignment="Center" IsActive="{Binding IsLoading}" />
          <TextBlock Text="{Binding LoadingText}" HorizontalAlignment="Center" FontSize="12"
                     TextWrapping="Wrap" TextAlignment="Center"
                     Foreground="{DynamicResource LatticeTextSecondaryBrush}" />
          <Border Height="12" CornerRadius="2" Background="{DynamicResource LatticeStrokeSubtleBrush}" />
          <Border Height="12" CornerRadius="2" Background="{DynamicResource LatticeStrokeSubtleBrush}" />
          <Border Height="12" CornerRadius="2" Background="{DynamicResource LatticeStrokeSubtleBrush}" />
        </StackPanel>
      </Border>

      <!-- Empty overlay. dataOverlay (issue #88): inset below the column header. -->
      <Border Classes="dataOverlay" IsVisible="{Binding IsEmpty}" Background="{DynamicResource LatticeSurfaceBrush}">
        <Panel>
          <TextBlock Text="{x:Static loc:Strings.TasksEmptyAll}" HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="13" Foreground="{DynamicResource LatticeTextSecondaryBrush}"
                     IsVisible="{Binding IsAllHostsScope}" />
          <TextBlock Text="{x:Static loc:Strings.TasksEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="13" Foreground="{DynamicResource LatticeTextSecondaryBrush}"
                     IsVisible="{Binding !IsAllHostsScope}" />
        </Panel>
      </Border>
      <!-- Partial-results warning. Overlay child, NOT docked in the flow: a closed
           FAInfoBar keeps its margin in a dock slot and pushed the grid 8px down
           (issue #107). Floating placement lives in the shared partialBar class. -->
      <ui:FAInfoBar Classes="partialBar" Severity="Warning" IsOpen="{Binding ShowPartialBar}"
                    Title="{x:Static loc:Strings.PartialTitle}" Message="{Binding PartialBarText}"
                    Closed="OnPartialBarClosed">
        <ui:FAInfoBar.ActionButton>
          <Button Content="{x:Static loc:Strings.RetryNow}" Command="{Binding RefreshCommand}" />
        </ui:FAInfoBar.ActionButton>
      </ui:FAInfoBar>
      <!-- Control-op failure surface (M3 PR F): the last ControlOpResult failure,
           dismissible, newer replaces older. Overlay child like the partial bar —
           NOT docked — but anchored BOTTOM so the two bars can never overlap
           (partial coverage floats at the top). IsVisible rides IsOpen so the
           CLOSED bar reserves zero layout space, margin included (issue #107:
           a closed docked FAInfoBar kept an 8px strip; geometry-pinned in
           TasksViewControlTests). -->
      <ui:FAInfoBar x:Name="ControlFailureBar" Classes="controlFailureBar" Severity="Error"
                    IsOpen="{Binding ControlFailure.IsOpen}"
                    IsVisible="{Binding ControlFailure.IsOpen}"
                    Title="{Binding ControlFailure.Title}"
                    Message="{Binding ControlFailure.Message}"
                    Closed="OnControlFailureClosed" />
    </Panel>
    </DockPanel>
  </DockPanel>
</UserControl>
